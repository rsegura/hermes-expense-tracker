# Expense Tracker MCP paths — product-specific variables only.
# bootstrap / add-member write these into each profile automatically.
#
# config.yaml references ${EXPENSE_MCP_PYTHON}, etc.; Hermes resolves them
# from the profile environment (typically this file).

EXPENSE_MCP_PYTHON=~/hermes-expense-tracker/mcp/expense-tracker/.venv/bin/python
EXPENSE_MCP_SERVER_PATH=~/hermes-expense-tracker/mcp/expense-tracker/server.py
EXPENSE_DB_PATH=~/.hermes/expense-tracker/expenses.db
EXPENSE_DEFAULT_CURRENCY=USD

# Model, API key, Telegram → profile config.yaml or:
#   hermes setup / <slug> gateway setup
# Not part of this product's install.
