# Rutas del Expense Tracker MCP — solo esto es específico de este producto.
# add-member.sh / bootstrap.sh las agregan al perfil automáticamente.
#
# Se usan porque config.yaml referencia ${EXPENSE_MCP_PYTHON}, etc.
# Hermes las resuelve desde el entorno del perfil (típicamente este archivo).

EXPENSE_MCP_PYTHON=~/hermes-expense-tracker/mcp/expense-tracker/.venv/bin/python
EXPENSE_MCP_SERVER_PATH=~/hermes-expense-tracker/mcp/expense-tracker/server.py
EXPENSE_DB_PATH=~/expenses/data/expenses.db

# Modelo, API key, Telegram → config.yaml del perfil o:
#   hermes setup / <slug> gateway setup
# No van acá como parte de este producto.
